{
  "name": "hono-scraper-api",
  "version": "1.0.0",
  "description": "Production-ready Hono.js scraping API for social media platforms",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "start": "node dist/index.js",
    "build:vercel": "bun build api/index.ts --outdir dist --target node",
    "build:cf": "bun build src/worker.ts --outdir dist --target browser",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "vercel:dev": "vercel dev",
    "vercel:deploy": "vercel deploy --prod"
  },
  "dependencies": {
    "hono": "^4.12.27",
    "zod": "^3.23.8",
    "@hono/zod-validator": "^0.2.2",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.5.1",
    "typescript": "^5.5.4",
    "@typescript-eslint/eslint-plugin": "^8.2.0",
    "@typescript-eslint/parser": "^8.2.0",
    "eslint": "^9.9.0",
    "prettier": "^3.3.3",
    "wrangler": "^3.72.0",
    "@vercel/node": "^3.0.0"
  }
}
